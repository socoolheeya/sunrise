    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "sunrise_api_key",
      "value": "test-prod-key"
    },
    {
      "key": "ingestion_wait_ms",
      "value": "3000"
    },
    {
      "key": "start",
      "value": "2026-06-01T00:00:00Z"
    },
    {
      "key": "end",
      "value": "2026-06-04T00:00:00Z"
    }
  ],
  "auth": {
    "type": "noauth"
