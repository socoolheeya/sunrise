                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Sunrise-Key",
                "value": "{{sunrise_api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schema_version\": \"tracking-event.v1\",\n  \"events\": [\n    {\"event_id\": \"pm-seed-001\", \"visitor_id\": \"v1\", \"session_id\": \"s-pm-1\", \"type\": \"view\", \"product_id\": \"p-shirt\", \"category\": \"tops\", \"utm_source\": \"kakao\", \"utm_medium\": \"paid_social\", \"utm_campaign\": \"summer_recovery\", \"landing_page\": \"https://shop.example/tops\", \"occurred_at\": \"2026-06-01T09:00:00Z\"},\n    {\"event_id\": \"pm-seed-002\", \"visitor_id\": \"v1\", \"session_id\": \"s-pm-1\", \"type\": \"cart_add\", \"product_id\": \"p-shirt\", \"category\": \"tops\", \"utm_source\": \"kakao\", \"utm_medium\": \"paid_social\", \"utm_campaign\": \"summer_recovery\", \"occurred_at\": \"2026-06-01T09:05:00Z\"},\n    {\"event_id\": \"pm-seed-003\", \"visitor_id\": \"v1\", \"session_id\": \"s-pm-1\", \"order_id\": \"o-pm-1\", \"type\": \"purchase\", \"product_id\": \"p-shirt\", \"category\": \"tops\", \"utm_source\": \"kakao\", \"utm_medium\": \"paid_social\", \"utm_campaign\": \"summer_recovery\", \"amount\": 120, \"occurred_at\": \"2026-06-01T09:10:00Z\"},\n    {\"event_id\": \"pm-seed-004\", \"visitor_id\": \"v2\", \"session_id\": \"s-pm-2\", \"type\": \"view\", \"product_id\": \"p-bag\", \"category\": \"bags\", \"utm_source\": \"google\", \"utm_medium\": \"organic\", \"landing_page\": \"https://shop.example/bags\", \"occurred_at\": \"2026-06-01T10:00:00Z\"},\n    {\"event_id\": \"pm-seed-005\", \"visitor_id\": \"v2\", \"session_id\": \"s-pm-2\", \"type\": \"cart_add\", \"product_id\": \"p-bag\", \"category\": \"bags\", \"utm_source\": \"google\", \"utm_medium\": \"organic\", \"occurred_at\": \"2026-06-01T10:05:00Z\"},\n    {\"event_id\": \"pm-seed-006\", \"visitor_id\": \"v3\", \"session_id\": \"s-pm-3\", \"type\": \"view\", \"product_id\": \"p-shoes\", \"category\": \"shoes\", \"utm_source\": \"direct\", \"utm_medium\": \"direct\", \"occurred_at\": \"2026-06-02T11:00:00Z\"},\n    {\"event_id\": \"pm-seed-007\", \"visitor_id\": \"v4\", \"session_id\": \"s-pm-4\", \"type\": \"view\", \"product_id\": \"p-shirt\", \"category\": \"tops\", \"utm_source\": \"email\", \"utm_medium\": \"email\", \"utm_campaign\": \"repeat_purchase\", \"occurred_at\": \"2026-06-02T12:00:00Z\"},\n    {\"event_id\": \"pm-seed-008\", \"visitor_id\": \"v4\", \"session_id\": \"s-pm-4\", \"order_id\": \"o-pm-4a\", \"type\": \"purchase\", \"product_id\": \"p-shirt\", \"category\": \"tops\", \"utm_source\": \"email\", \"utm_medium\": \"email\", \"utm_campaign\": \"repeat_purchase\", \"amount\": 80, \"occurred_at\": \"2026-06-02T12:20:00Z\"},\n    {\"event_id\": \"pm-seed-009\", \"visitor_id\": \"v4\", \"session_id\": \"s-pm-5\", \"order_id\": \"o-pm-4b\", \"type\": \"purchase\", \"product_id\": \"p-bag\", \"category\": \"bags\", \"utm_source\": \"email\", \"utm_medium\": \"email\", \"utm_campaign\": \"repeat_purchase\", \"amount\": 200, \"occurred_at\": \"2026-06-03T12:20:00Z\"}\n  ]\n}"
            },
            "url": "{{base_url}}/v1/collect"
          }
        },
        {
          "name": "Wait for Kafka to ClickHouse",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const waitMs = Number(pm.collectionVariables.get('ingestion_wait_ms') || 3000);",
                  "const startedAt = Date.now();",
                  "while (Date.now() - startedAt < waitMs) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/healthz"
          }
        }
      ]
    },
